{
  "name": "nemo-context",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "1.0.0",
  "publisher": "blaackzero",
  "license": "MIT",
  "l10n": "./l10n",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlaackZero/MemoryManager.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "AI"
  ],
  "activationEvents": [
    "onView:nemo.memories"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nemo",
          "title": "%views.nemo.title%",
          "icon": "$(notebook)"
        }
      ]
    },
    "views": {
      "nemo": [
        {
          "id": "nemo.memories",
          "name": "%views.memories.name%",
          "enableDragAndDrop": true
        }
      ]
    },
    "commands": [
      {
        "command": "nemo.createMemory",
        "title": "%command.createMemory.title%",
        "icon": "$(add)"
      },
      {
        "command": "nemo.createFolder",
        "title": "%command.createFolder.title%",
        "icon": "$(new-folder)"
      },
      {
        "command": "nemo.editMemory",
        "title": "%command.editMemory.title%",
        "icon": "$(edit)"
      },
      {
        "command": "nemo.injectMemory",
        "title": "%command.injectMemory.title%",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "nemo.shareToRepo",
        "title": "%command.shareToRepo.title%",
        "icon": "$(repo-push)"
      },
      {
        "command": "nemo.unshareFromRepo",
        "title": "%command.unshareFromRepo.title%",
        "icon": "$(person)"
      },
      {
        "command": "nemo.openSharedFolder",
        "title": "%command.openSharedFolder.title%",
        "icon": "$(folder-opened)"
      },
      {
        "command": "nemo.deleteMemory",
        "title": "%command.deleteMemory.title%",
        "icon": "$(trash)"
      },
      {
        "command": "nemo.deleteFolder",
        "title": "%command.deleteFolder.title%",
        "icon": "$(trash)"
      },
      {
        "command": "nemo.renameNode",
        "title": "%command.renameNode.title%",
        "icon": "$(edit)"
      },
      {
        "command": "nemo.setNodeStyle",
        "title": "%command.setNodeStyle.title%",
        "icon": "$(symbol-color)"
      },
      {
        "command": "nemo.refresh",
        "title": "%command.refresh.title%",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "nemo.createMemory",
          "when": "view == nemo.memories && workspaceFolderCount > 0",
          "group": "navigation@1"
        },
        {
          "command": "nemo.createFolder",
          "when": "view == nemo.memories && workspaceFolderCount > 0",
          "group": "navigation@2"
        },
        {
          "command": "nemo.openSharedFolder",
          "when": "view == nemo.memories && workspaceFolderCount > 0",
          "group": "navigation@3"
        },
        {
          "command": "nemo.refresh",
          "when": "view == nemo.memories",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "nemo.createMemory",
          "when": "view == nemo.memories && (viewItem == sharedMemoryFolder || viewItem == personalMemoryFolder || viewItem == sharedSection || viewItem == personalSection)",
          "group": "1_creation@1"
        },
        {
          "command": "nemo.createFolder",
          "when": "view == nemo.memories && (viewItem == sharedMemoryFolder || viewItem == personalMemoryFolder || viewItem == sharedSection || viewItem == personalSection)",
          "group": "1_creation@2"
        },
        {
          "command": "nemo.editMemory",
          "when": "view == nemo.memories && (viewItem == sharedMemoryFile || viewItem == personalMemoryFile)",
          "group": "inline@1"
        },
        {
          "command": "nemo.injectMemory",
          "when": "view == nemo.memories && (viewItem == sharedMemoryFile || viewItem == personalMemoryFile)",
          "group": "inline@2"
        },
        {
          "command": "nemo.shareToRepo",
          "when": "view == nemo.memories && (viewItem == personalMemoryFile || viewItem == personalMemoryFolder)",
          "group": "2_sync@1"
        },
        {
          "command": "nemo.unshareFromRepo",
          "when": "view == nemo.memories && (viewItem == sharedMemoryFile || viewItem == sharedMemoryFolder)",
          "group": "2_sync@2"
        },
        {
          "command": "nemo.renameNode",
          "when": "view == nemo.memories && (viewItem == sharedMemoryFile || viewItem == sharedMemoryFolder || viewItem == personalMemoryFile || viewItem == personalMemoryFolder)",
          "group": "7_modification@1"
        },
        {
          "command": "nemo.setNodeStyle",
          "when": "view == nemo.memories && (viewItem == sharedMemoryFile || viewItem == sharedMemoryFolder || viewItem == personalMemoryFile || viewItem == personalMemoryFolder)",
          "group": "7_modification@2"
        },
        {
          "command": "nemo.deleteMemory",
          "when": "view == nemo.memories && (viewItem == sharedMemoryFile || viewItem == personalMemoryFile)",
          "group": "7_modification@3"
        },
        {
          "command": "nemo.deleteFolder",
          "when": "view == nemo.memories && (viewItem == sharedMemoryFolder || viewItem == personalMemoryFolder)",
          "group": "7_modification@4"
        },
        {
          "command": "nemo.openSharedFolder",
          "when": "view == nemo.memories && viewItem == sharedSection",
          "group": "8_explore@1"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "nemo.storageLocation": {
          "type": "string",
          "enum": [
            "home",
            "globalStorage"
          ],
          "default": "home",
          "description": "%config.storageLocation.description%"
        },
        "nemo.repoIdStrategy": {
          "type": "string",
          "enum": [
            "workspaceName",
            "pathHash"
          ],
          "default": "workspaceName",
          "description": "%config.repoIdStrategy.description%"
        },
        "nemo.sharedPath": {
          "type": "string",
          "default": ".nemo",
          "description": "%config.sharedPath.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src test --ext ts",
    "test": "npm run compile && node ./out/test/runTest.js",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.1",
    "eslint": "^8.57.0",
    "glob": "^10.4.5",
    "mocha": "^10.7.3",
    "typescript": "^5.4.0"
  }
}
