{
  "name": "repo-memory",
  "displayName": "Repo Memory",
  "description": "Gestiona memorias de contexto por repositorio fuera del workspace Git",
  "version": "0.1.0",
  "publisher": "blaackzero",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "AI"
  ],
  "activationEvents": [
    "onView:repoMemory.memories"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "repoMemory",
          "title": "Repo Memory",
          "icon": "$(notebook)"
        }
      ]
    },
    "views": {
      "repoMemory": [
        {
          "id": "repoMemory.memories",
          "name": "Memorias"
        }
      ]
    },
    "commands": [
      {
        "command": "repoMemory.createMemory",
        "title": "Nueva memoria",
        "icon": "$(add)"
      },
      {
        "command": "repoMemory.editMemory",
        "title": "Editar memoria",
        "icon": "$(edit)"
      },
      {
        "command": "repoMemory.injectMemory",
        "title": "Inyectar en Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "repoMemory.deleteMemory",
        "title": "Eliminar memoria",
        "icon": "$(trash)"
      },
      {
        "command": "repoMemory.refresh",
        "title": "Actualizar",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "repoMemory.createMemory",
          "when": "view == repoMemory.memories && workspaceFolderCount > 0",
          "group": "navigation@1"
        },
        {
          "command": "repoMemory.refresh",
          "when": "view == repoMemory.memories",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "repoMemory.editMemory",
          "when": "view == repoMemory.memories && viewItem == memoryFile",
          "group": "inline@1"
        },
        {
          "command": "repoMemory.injectMemory",
          "when": "view == repoMemory.memories && viewItem == memoryFile",
          "group": "inline@2"
        },
        {
          "command": "repoMemory.deleteMemory",
          "when": "view == repoMemory.memories && viewItem == memoryFile",
          "group": "7_modification"
        }
      ]
    },
    "configuration": {
      "title": "Repo Memory",
      "properties": {
        "repoMemory.storageLocation": {
          "type": "string",
          "enum": [
            "home",
            "globalStorage"
          ],
          "default": "home",
          "description": "Ubicación del almacenamiento: home (~/.repo-memory-store) o globalStorage de la extensión."
        },
        "repoMemory.repoIdStrategy": {
          "type": "string",
          "enum": [
            "workspaceName",
            "pathHash"
          ],
          "default": "workspaceName",
          "description": "Estrategia para identificar el repositorio: nombre del workspace o hash de la ruta."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src test --ext ts",
    "test": "npm run compile && node ./out/test/runTest.js",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.1",
    "eslint": "^8.57.0",
    "glob": "^10.4.5",
    "mocha": "^10.7.3",
    "typescript": "^5.4.0"
  }
}
